{
  "name": "@construct-space/cli",
  "version": "1.1.2",
  "description": "Construct CLI — scaffold, build, develop, and publish spaces",
  "type": "module",
  "bin": {
    "construct": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm && cp -r templates dist/",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "ora": "^9.3.0",
    "chokidar": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "construct",
    "cli",
    "space",
    "graph"
  ],
  "author": {
    "name": "Construct Team"
  },
  "license": "MIT"
}
