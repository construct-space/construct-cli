{
  "name": "construct",
  "version": "1.0.0",
  "description": "Construct CLI — scaffold, build, develop, and publish spaces",
  "type": "module",
  "bin": {
    "construct": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm && cp -r templates dist/",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "ora": "^9.3.0",
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "construct",
    "cli",
    "space",
    "graph"
  ],
  "author": {
    "name": "Construct Team"
  },
  "license": "MIT"
}
